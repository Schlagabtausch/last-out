[sub_resource type="GDScript" id="GDScript_g2els"]
script/source = "extends CharacterBody2D

# Bewegungsgeschwindigkeit der Spielfigur in Pixel pro Sekunde.
# Dieser Wert kann im Inspector in Godot angepasst werden.
@export var speed: float = 160.0

# Referenz auf die Bullet-Szene.
# Hier wird im Inspector die Szene eingetragen, die beim Schießen erzeugt werden soll.
@export var bullet_scene: PackedScene

# Verknüpfung mit dem AnimatedSprite2D-Knoten der Spielfigur.
# Über diese Variable können Animationen gestartet oder abgefragt werden.
@onready var anim: AnimatedSprite2D = $AnimatedSprite2D

# Verknüpfung mit dem AudioStreamPlayer2D für die Schrittgeräusche.
# Dieser Knoten spielt beim Laufen die Footstep-Sounds ab.
@onready var footsteps: AudioStreamPlayer2D = $Footsteps

# Verknüpfung mit einem Marker2D-Knoten namens \"Muzzle\".
# Dieser Marker gibt an, an welcher Position die Kugel erzeugt werden soll.
@onready var muzzle: Marker2D = $Muzzle

# Speichert die aktuelle Blickrichtung der Spielfigur.
# Diese Richtung wird für Idle- und Laufanimationen verwendet.
# Standardmäßig schaut die Figur am Anfang nach unten.

# Hint for Player to interact with object
@onready var interaction_hint = $InteractionHint

var last_direction: String = \"down\"

# Player freezes when interacting with consoles
var is_frozen: bool = false

func _ready() -> void:
	# _ready() wird einmal aufgerufen, sobald der Node und alle seine Kinder
	# vollständig geladen und bereit sind.
	
	# Hier verbinden wir das Signal \"frame_changed\" des AnimatedSprite2D
	# mit der Funktion _on_anim_frame_changed().
	# Dadurch wird unsere Funktion immer dann aufgerufen,
	# wenn der aktuelle Animationsframe wechselt.
	anim.frame_changed.connect(_on_anim_frame_changed)
	# Damit die Tür nur auf Player reagiert
	# wird er in group \"player\" hinzugefügt
	add_to_group(\"player\")

func _physics_process(_delta: float) -> void:
	# _physics_process() wird in festen Physik-Abständen aufgerufen.
	# Diese Funktion ist ideal für Bewegung und Kollisionen.
	
	# Liest die Eingaben für die vier Bewegungsrichtungen aus.
	# \"move_left\", \"move_right\", \"move_up\" und \"move_down\"
	# müssen vorher im Input-Manager von Godot angelegt worden sein.
	#
	# Das Ergebnis ist ein Vector2:
	# (-1, 0) = links
	# ( 1, 0) = rechts
	# ( 0,-1) = oben
	# ( 0, 1) = unten
	# diagonale Kombinationen sind ebenfalls möglich.
	var input_dir := Input.get_vector(\"move_left\", \"move_right\", \"move_up\", \"move_down\")
	
	
	if is_frozen:
		velocity = Vector2.ZERO
		move_and_slide()
		update_animation(Vector2.ZERO)
		return
	
	# Setzt die Bewegungsrichtung der Figur.
	# input_dir enthält nur die Richtung.
	# Durch Multiplikation mit speed entsteht die tatsächliche Geschwindigkeit.
	velocity = input_dir * speed
	
	# Bewegt die Figur anhand von velocity
	# und berücksichtigt dabei Kollisionen automatisch.
	move_and_slide()

	# Aktualisiert die Blickrichtung anhand der aktuellen Mausposition.
	# Die Bewegungsrichtung und die Blickrichtung sind dadurch getrennt.
	update_look_direction()

	# Passt die abgespielte Animation an:
	# Laufanimation bei Bewegung, Idle-Animation im Stand.
	update_animation(input_dir)


func update_look_direction() -> void:
	
	var input_dir := Input.get_vector(\"move_left\", \"move_right\", \"move_up\", \"move_down\")
	
	if input_dir == Vector2.ZERO:
		return

	if abs(input_dir.y) > abs(input_dir.x):
		if input_dir.y > 0:
			last_direction = \"down\"
		else:
			last_direction = \"up\"
	else:
		if input_dir.x > 0:
			last_direction = \"right\"
		else:
			last_direction = \"left\"



func update_animation(input_dir: Vector2) -> void:
	# Prüft, ob sich die Spielfigur gerade bewegt.
	# Vector2.ZERO bedeutet: keine Eingabe, also keine Bewegung.
	if input_dir != Vector2.ZERO:
		# Spielt die passende Laufanimation ab.
		# Beispiel:
		# last_direction = \"left\"  -> \"walk_left\"
		# last_direction = \"up\"    -> \"walk_up\"
		anim.play(\"walk_\" + last_direction)

		# Startet die Schrittgeräusche nur dann,
		# wenn sie nicht bereits abgespielt werden.
		if not footsteps.playing:
			footsteps.play()
	else:
		# Wenn keine Bewegung stattfindet,
		# wird die Idle-Animation in Blickrichtung abgespielt.
		# Beispiel:
		# \"idle_down\", \"idle_right\" usw.
		anim.play(\"idle_\" + last_direction)
		
		# Im Stand sollen keine Schrittgeräusche abgespielt werden.
		footsteps.stop()
		



func _on_anim_frame_changed() -> void:
	# Diese Funktion wird automatisch aufgerufen,
	# sobald sich der aktuelle Frame der Animation ändert.
	
	# Prüft zunächst, ob gerade überhaupt eine Laufanimation abgespielt wird.
	# begins_with(\"walk_\") trifft z. B. auf \"walk_up\" oder \"walk_left\" zu.
	if anim.animation.begins_with(\"walk_\"):
		# Prüft, ob der aktuelle Frame einer der gewünschten \"Fußkontakt\"-Frames ist.
		# Hier wurden beispielhaft Frame 0 und Frame 2 gewählt.
		if anim.frame == 0 or anim.frame == 2:
			# Schrittgeräusch nur starten, wenn es gerade nicht bereits läuft.
			if not footsteps.playing:
				footsteps.play()
				
				
func set_interaction_hint(is_visible: bool):
	interaction_hint.visible = is_visible
"

