[sub_resource type="GDScript" id="GDScript_jkv2x"]
script/source = "extends Control

@onready var boot_label = %BootLabel
@onready var fade_screen = %FadeScreen
@onready var ap_label = %APLabel
@onready var player = %Player

func _ready():
	
	player.is_frozen = true;
	await _play_boot_sequence()   
	var tween = create_tween()
	tween.tween_property(fade_screen, \"modulate:a\", 0.0, 1.5)
	await tween.finished
	fade_screen.hide()
	
	if GlobalConstants.is_first_run:
		_start_first_run_dialog()
		GlobalConstants.is_first_run = false
	else:
		_start_gameplay()

func _play_boot_sequence():
	boot_label.show()
	ap_label.hide()
	await get_tree().create_timer(2.0).timeout 
	boot_label.hide()

func _start_first_run_dialog():
	var dialogue = [
		{
			\"image\": GlobalConstants.PORTRAIT_OPERATOR, 
			\"text\": \"UNIT-L, do you copy? Report status.\"
		},
		{
			\"image\": GlobalConstants.PORTRAIT_UNIT_L, 
			\"text\": \"Connection active. Status: Log-Entry 08.14.2084. Base integrity low. Environmental hazard detected: Lethal radiation levels.\"
		},
		{
			\"image\": GlobalConstants.PORTRAIT_OPERATOR, 
			\"text\": \"I see. UNIT-L, the crew evacuated during the initial containment breach. You were left behind in the panic. You are the only unit still operational.\"		},
		{
			\"image\": GlobalConstants.PORTRAIT_UNIT_L, 
			\"text\": \"Acknowledgement. I am a logistical maintenance unit. My hardware was not designed for this environment. My core systems are failing.\"
		},
		{
			\"image\": GlobalConstants.PORTRAIT_OPERATOR, 
			\"text\": \"You have to reach the core, UNIT-L. Extract the quantum research data. It's the only priority.\"
		},
		{
			\"image\": GlobalConstants.PORTRAIT_UNIT_L, 
			\"text\": \"Warning: The quantum anomaly has rendered this uplink volatile. Power reserves are critically low. I can perform a maximum of 3 complex actions before sync-stability collapses.\"
		},
		{
			\"image\": GlobalConstants.PORTRAIT_UNIT_L, 
			\"text\": \"Upon collapse, the local time-impulse will trigger a hard reset, returning my physical chassis to this exact moment. Multiple iterations will likely be required.\"
		},
		{
			\"image\": GlobalConstants.PORTRAIT_OPERATOR, 
			\"text\": \"Understood. The station resets, but I don't. I will manually log all passcodes, security layouts, and variables we discover. My memory is our only persistent asset.\"
		},
		{
			\"image\": GlobalConstants.PORTRAIT_OPERATOR, 
			\"text\": \"Use your actions to push as far as you can and gather intel, then let the loop reset. Let's get to work, UNIT-L.\"
		}
	] 
	DialogSystem.start_dialog(dialogue)
	await DialogSystem.dialog_finished
	_start_gameplay()

func _start_gameplay():
	player.is_frozen = false
	ap_label.show()
"

